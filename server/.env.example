# Variables de entorno — QResto
# Copia este archivo a .env y ajusta los valores

PORT=3000

# Contraseña del panel admin (cámbiala en producción)
QRESTO_ADMIN_PASSWORD=qresto2026
# Contraseña del panel camarero
QRESTO_CAMARERO_PASSWORD=camarero2026

# URL pública del sitio (para QR de mesas en producción). Ej: https://qresto.onrender.com
# QRESTO_BASE_URL=https://tu-dominio.com

# MySQL (opcional — sin MySQL usa archivos JSON)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=qresto

# Pon 1 para forzar JSON sin intentar MySQL
# MYSQL_DISABLED=1
